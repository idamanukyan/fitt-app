# HyperFit Mobile App Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration
# =============================================================================
EXPO_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# AI Food Scanner API Keys
# =============================================================================

# Google Gemini (60 requests/min free)
# https://makersuite.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace (free inference API)
# https://huggingface.co/settings/tokens
EXPO_PUBLIC_HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Groq (free tier available)
# https://console.groq.com/keys
EXPO_PUBLIC_GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# Google OAuth
# Get these from: https://console.cloud.google.com/apis/credentials
# =============================================================================
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# =============================================================================
# Apple Sign In
# Get these from: https://developer.apple.com/account/resources/identifiers/list/serviceId
# =============================================================================
EXPO_PUBLIC_APPLE_SERVICE_ID=com.hyperfit.auth

# =============================================================================
# Facebook OAuth
# Get these from: https://developers.facebook.com/apps/
# =============================================================================
EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# =============================================================================
# Analytics (Mixpanel)
# =============================================================================
EXPO_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# =============================================================================
# Weather API (OpenWeatherMap)
# Get your free API key from: https://openweathermap.org/api
# Free tier: 60 calls/minute, 1,000,000 calls/month
# =============================================================================
EXPO_PUBLIC_OPENWEATHER_API_KEY=your-openweather-api-key-here
